# =============================================================================
# GeneGuidelines — copy to repo root on the server:
#
#   cp backend/.env.example .env
#   nano .env   # set LLM_BASE_URL to your remote vLLM host
#
# docker-compose.yml loads ONLY this root `.env` (never commit real secrets).
# =============================================================================

# --- Database (Postgres required) ---
# Local pytest / bare metal:
#   DB_URL=postgresql://ggapp:testpass@localhost:5432/geneguidelines
# Docker Compose (service hostname `postgres`; compose sets this automatically):
#   DB_URL=postgresql://ggapp:testpass@postgres:5432/geneguidelines
# Optional overrides for the postgres service (defaults match below):
# POSTGRES_USER=ggapp
# POSTGRES_PASSWORD=testpass
# POSTGRES_DB=geneguidelines
# POSTGRES_PORT=5432
DB_URL=postgresql://ggapp:testpass@localhost:5432/geneguidelines

# --- Model routing (remote self-hosted Gemma via vLLM) ---
MODEL_PROFILE=vllm
LLM_BASE_URL=https://YOUR-VLLM-HOST:8000/v1
LLM_MODEL=google/gemma-4-26B-A4B-it
LLM_API_KEY=gene-guidelines-local

# Explicit defaults (avoids falling back to openai:* when nodes omit provider prefix)
DEFAULT_LLM_MODEL=vllm:google/gemma-4-26B-A4B-it
DEFAULT_SIMPLE_LLM_MODEL=vllm:google/gemma-4-26B-A4B-it
DEFAULT_AGENTIC_LLM_MODEL=vllm:google/gemma-4-26B-A4B-it
# Use "raw" if your gateway expects Authorization: <key> without "Bearer "
# LLM_AUTH_HEADER_STYLE=raw

# If vLLM runs on the SAME machine as Docker (not typical on OVH b3-16):
# LLM_BASE_URL=http://host.docker.internal:8000/v1

# --- Demo / stability (shorter PubMed, fewer parallel LLM calls) ---
SIMPLE_LLM_PARALLEL_CONCURRENCY=1
FINDER_LLM_PARALLEL_CONCURRENCY=2
# Per-batch wait for trials/therapies/foundations structured extraction (asyncio.wait_for).
FINDER_LLM_TIMEOUT_SEC=360
PUBMED_RETRIEVAL_TARGET_PMIDS=200
PUBMED_RETRIEVAL_MIN_PMIDS_PER_DOMAIN=30

# Long runs (PubMed + many nodes) — default 6h; lower only if you want hard stop
# AGENT_RUN_TIMEOUT_SEC=21600

# --- Public demo: leave API key unset so browsers work without VITE_GENEGUIDELINES_API_KEY ---
# GENEGUIDELINES_API_KEY=

# Local dev without Clerk: set ALLOW_DEV_AUTH_BYPASS=1 (never in production).
# ALLOW_DEV_AUTH_BYPASS=1

# --- Clerk (same app; both required when the public site uses Clerk sign-in) ---
# Frontend (Vite): VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Backend (API):   CLERK_SECRET_KEY=sk_test_...
# CLERK_SECRET_KEY=sk_test_...
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# Production: set authorized parties so JWTs are accepted only from your frontends (azp/aud).
# CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://localhost:5174,https://geneguidelines.genequest.org
# Fail startup if Clerk is on but parties are missing (production deploys):
# CLERK_REQUIRE_AUTHORIZED_PARTIES=1
# Verbose JWT errors for debugging (default: generic message):
# CLERK_VERBOSE_AUTH_ERRORS=1
# Clerk role cache TTL when resolving admin via Users API (seconds; default 300).
# CLERK_ROLE_CACHE_TTL_SEC=300
# Disease metadata lookup (LLM) per user — separate from research-run quota.
# METADATA_LOOKUP_RATE_LIMIT_MAX=30
# METADATA_LOOKUP_RATE_LIMIT_WINDOW_SEC=3600
# Research-run quota (user role): 3 starts per 24h; admin role is unlimited (skips check).
# BOOTSTRAP_RATE_LIMIT_MAX_USER=3
# BOOTSTRAP_RATE_LIMIT_WINDOW_SEC=86400
# BOOTSTRAP_RATE_LIMIT_MAX_PER_WINDOW=50
# BOOTSTRAP_RATE_LIMIT_MAX_ADMIN=50  # unused while admin skips the limiter

# --- Optional: faster PubMed E-utilities (recommended if you have a key) ---
# Strongly recommended on prod / bootstrap runs — without it NCBI rate-limits to ~3 req/s (429 errors).
# NCBI_API_KEY=

# --- Optional: Doctor Finder geo enrichment ---
# BRAVE_API_KEY=

# =============================================================================
# Cloud profiles (do NOT enable together with MODEL_PROFILE=vllm above)
# =============================================================================
# MODEL_PROFILE=production
# OPENAI_API_KEY=sk-...
# DEFAULT_SIMPLE_LLM_MODEL=openai:gpt-5.5
# DEFAULT_AGENTIC_LLM_MODEL=openai:gpt-5.5
# MODEL_PROFILE_PRODUCTION_OVERFLOW=openai:gpt-5.4
# DEFAULT_SIMPLE_LLM_MAX_TOKENS=128000
# DEFAULT_AGENTIC_LLM_MAX_TOKENS=128000
# OPENAI_TPM_REQUEST_TOKEN_BUDGET=380000
# SIMPLE_LLM_PARALLEL_CONCURRENCY=1
# LLM_PROMPT_TOKEN_CAP=200000  # model-context cap; lower to 200k for Gemma 4 (262k window), raise to ~350k for GPT-5.5 long-context
# LLM_PROMPT_TOKEN_CAP_VLLM=60000  # tighter cap when MODEL_PROFILE=vllm / SINGLE_LLM_MODE
# PUBMED_PM3_TOP_K=100
# PUBMED_PASS1_TOP_K=80
# PUBMED_PROMPT_ABSTRACT_MAX_CHARS=800  # prompt view only; pm-2 store keeps PUBMED_ARTICLES_TEXT_ABSTRACT_MAX_CHARS

# MODEL_PROFILE=openrouter
# OPENROUTER_API_KEY=sk-or-...
