# Copy to repo root `.env` or `backend/.env` (both are loaded). Never commit real secrets.

# --- Required for LLM runs (production profile) ---
OPENAI_API_KEY=

# --- Optional API protection (admin mutations, SSE with ?api_key=) ---
# GENEGUIDELINES_API_KEY=

# --- Alternate model profiles ---
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# MODEL_PROFILE=production

# --- PubMed / NCBI ---
# NCBI_API_KEY=

# --- Doctor Finder geo (Brave + LLM) ---
# BRAVE_API_KEY=
# DOCTOR_FINDER_GEO_MAX_AFFILIATIONS=280
# DOCTOR_FINDER_GEO_BRAVE_CONCURRENCY=4
# DOCTOR_FINDER_GEO_CONFIDENCE_MIN=0.66
# DOCTOR_FINDER_GEO_MIN_AFF_CHARS=14
# DOCTOR_FINDER_RELEVANCE_LEAD_CHARS=700

# --- Runtime / CI ---
# AGENT_NO_MCP_RUNTIME=1
# AGENT_RUN_TIMEOUT_SEC=21600
# AGENT_PYDANTIC_AI_REQUEST_LIMIT=250
