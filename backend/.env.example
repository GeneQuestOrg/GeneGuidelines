# Copy to repo root `.env` or `backend/.env` (both are loaded). Never commit real secrets.

# --- Primary LLM: self-hosted OpenAI-compatible endpoint (all pipelines use this when set) ---
MODEL_PROFILE=vllm
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=your-model-id
LLM_API_KEY=
# Use "raw" when the gateway expects Authorization: <key> (no "Bearer " prefix).
# LLM_AUTH_HEADER_STYLE=raw

# --- Optional cloud profiles (ignored when LLM_BASE_URL + LLM_API_KEY are set) ---
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# MODEL_PROFILE=production

# Legacy aliases (optional; LLM_* takes precedence)
# VLLM_BASE_URL=
# VLLM_MODEL=
# VLLM_API_KEY=

# --- Optional API protection (admin mutations, SSE with ?api_key=) ---
# GENEGUIDELINES_API_KEY=

# --- PubMed / NCBI ---
# NCBI_API_KEY=

# --- Doctor Finder geo (Brave + LLM) ---
# BRAVE_API_KEY=
# DOCTOR_FINDER_GEO_MAX_AFFILIATIONS=280
# DOCTOR_FINDER_GEO_BRAVE_CONCURRENCY=4
# DOCTOR_FINDER_GEO_CONFIDENCE_MIN=0.66
# DOCTOR_FINDER_GEO_MIN_AFF_CHARS=14
# DOCTOR_FINDER_RELEVANCE_LEAD_CHARS=700

# --- Runtime / CI ---
# AGENT_NO_MCP_RUNTIME=1
# AGENT_RUN_TIMEOUT_SEC=21600
# AGENT_PYDANTIC_AI_REQUEST_LIMIT=250
