# Copy to repo root: cp backend/.env.example .env  (compose loads root `.env` only)

# --- vLLM / self-hosted OpenAI-compatible API (recommended for this project) ---
MODEL_PROFILE=vllm
LLM_BASE_URL=http://your-gateway-host:8000/v1
LLM_MODEL=your-model-id
LLM_API_KEY=your-api-key-or-empty-if-not-required
# LLM_AUTH_HEADER_STYLE=raw

# Docker on Mac when LLM runs on the host machine:
# LLM_BASE_URL=http://host.docker.internal:8000/v1

# --- Cloud alternatives ---
# MODEL_PROFILE=openrouter
# OPENROUTER_API_KEY=sk-or-...

# MODEL_PROFILE=production
# OPENAI_API_KEY=sk-...

# --- Optional ---
# GENEGUIDELINES_API_KEY=
# NCBI_API_KEY=
# BRAVE_API_KEY=
