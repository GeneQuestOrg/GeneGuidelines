# Admin app origin (dev default: http://localhost:5174). Opens in a new tab from the public header.
# VITE_ADMIN_URL=http://localhost:5174
# Optional: legacy full ops panel until admin migration (dev default: http://localhost:5175)
# VITE_LEGACY_OPS_URL=http://localhost:5175

# Data layer: api (default; backend SQLite via Vite proxy → :8000) or fixture
# (bundled TS seed for offline dev / Storybook-style demos).
# Production and `make dev` use the api default. Override with VITE_DATA_SOURCE=fixture
# if you want to work on the frontend without running uvicorn.
# VITE_DATA_SOURCE=fixture

# Optional: full backend origin (no trailing slash, no /api suffix). Leave unset for dev/preview — Vite proxies /api.
# VITE_API_URL=http://127.0.0.1:8000

# --- Auth0 (sign-in, role picker) ---
# Env-gated: leave VITE_AUTH0_DOMAIN unset and the app runs exactly as today —
# no Auth0 provider, sign-in button hidden, anonymous read-only access.
# Set all three (from your Auth0 SPA application + API) to enable sign-in.
# VITE_AUTH0_DOMAIN is the single switch; the others are read alongside it.
# VITE_AUTH0_DOMAIN=your-tenant.eu.auth0.com
# VITE_AUTH0_CLIENT_ID=your-spa-client-id
# Identifier of the backend API in Auth0 (must equal backend AUTH0_AUDIENCE).
# VITE_AUTH0_AUDIENCE=https://api.geneguidelines.org

# Do NOT set VITE_GENEGUIDELINES_API_KEY for production public builds.
# Vite embeds every VITE_* variable in the client bundle — anyone can read it in DevTools.
# The public site should use unauthenticated read APIs only; keep mutations on the admin subdomain.
# Exception (dev/staging only): when the backend has GENEGUIDELINES_API_KEY set, you may mirror it here
# so "Start research" on the public app can POST /api/pipeline/guideline-run and open SSE trace.
# VITE_GENEGUIDELINES_API_KEY=
