# Public site origin (dev default: http://localhost:5173) — link back from admin header
# VITE_PUBLIC_URL=http://localhost:5173

# Optional: full backend origin (no trailing slash, no /api suffix). Leave unset for dev/preview — Vite proxies /api.
# VITE_API_URL=http://127.0.0.1:8000

# --- Auth0 (superadmin gate) ---
# Env-gated: leave VITE_AUTH0_DOMAIN unset and the admin app stays in API-key mode
# (VITE_GENEGUIDELINES_API_KEY below) with no login gate — unchanged from today.
# Set all three to put the whole panel behind Auth0 login + a superadmin-role check.
# VITE_AUTH0_DOMAIN is the single switch; the others are read alongside it.
# VITE_AUTH0_DOMAIN=your-tenant.eu.auth0.com
# VITE_AUTH0_CLIENT_ID=your-spa-client-id
# Identifier of the backend API in Auth0 (must equal backend AUTH0_AUDIENCE).
# VITE_AUTH0_AUDIENCE=https://api.geneguidelines.org

# Optional dev/staging only: same value as backend GENEGUIDELINES_API_KEY (Bearer / X-API-Key).
# WARNING: Vite embeds VITE_* in the client bundle — not a substitute for per-user auth in production.
# Prefer network restrictions on admin.* and rotate the key if the bundle is ever exposed.
# VITE_GENEGUIDELINES_API_KEY=
